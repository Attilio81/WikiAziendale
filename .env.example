# Database
# Local dev (direct uvicorn): relative to backend/ directory
# Docker Compose: overridden to sqlite:////data/llm_wiki.db via compose environment
DATABASE_URL=sqlite:///./llm_wiki.db

# LLM Provider
LLM_PROVIDER=lmstudio

# LM Studio (OpenAI-compatible local, default dev)
# Running on dedicated Mac Mini M1 8GB with qwen/qwen3-8b
LMSTUDIO_BASE_URL=http://192.168.44.150:1234/v1
LMSTUDIO_MODEL_COMPILER=qwen/qwen3-8b
LMSTUDIO_MODEL_QUERY=qwen/qwen3-8b

# OpenAI (staging/demo)
OPENAI_API_KEY=
OPENAI_MODEL_COMPILER=gpt-4o-mini
OPENAI_MODEL_QUERY=gpt-4o-mini

# OpenRouter (prod option A)
OPENROUTER_API_KEY=
OPENROUTER_MODEL_COMPILER=qwen/qwen3-30b-a3b
OPENROUTER_MODEL_QUERY=qwen/qwen3-30b-a3b

# Azure OpenAI (prod option C, EU data residency)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_COMPILER=gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT_QUERY=gpt-4o-mini

# API
API_KEY=dev-change-me
API_CORS_ORIGINS=http://localhost:5173

# Agent settings (used from Phase 2)
# Suppress <think> tokens for Qwen3 models. Compiler can keep thinking for better quality.
LLM_DISABLE_THINKING_COMPILER=false
LLM_DISABLE_THINKING_QUERY=true
COMPILER_TIMEOUT_SECONDS=180
QUERY_TIMEOUT_SECONDS=30
COMPILER_MAX_RETRIES=1

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
